#include<iostream>
using namespace std;
void del(int arr[], int n, int pos, int max){
if(n>=max){
cout<<"Invalid";
}
else if(pos<0 || pos>n){
cout<<"Not True";
}
else{
for(int i=pos;i<n-1;i++){
arr[i]=arr[i+1];
}
}
}
int main(){
int arr[5]={1,2,3,4,5};
del(arr,5,3,12);
for(int i=0;i<4;i++){
cout<<endl<<arr[i]<<endl;
}
return 0;
}
