#include<iostream>
using namespace std;
void inarr(int arr[], int n, int pos, int val){
if(pos<0 || pos>n){
cout<<"Invalid";
}
for(int i=n;i>pos;i--){
arr[i]=arr[i-1];
}
arr[pos]=3;
n++;
cout<<"Inserted";
}
int main(){
int arr[5]={1,3,4,56,87};
inarr(arr,5,3,60);
for(int i=0;i<=5;i++){
    cout<<endl<<arr[i]<<endl;

}
return 0;
}
